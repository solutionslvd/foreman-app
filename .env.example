# ============================================================
#  Foreman AI — Environment Variables Reference
#  Copy this file to .env for local development
#  Set these values in Render Dashboard → Environment for prod
# ============================================================

# ── Security (REQUIRED) ──────────────────────────────────────────────────────

# JWT signing key for user sessions — generate a strong random string
# python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-use-a-long-random-string-in-production

# JWT signing key for admin sessions (can be same as SECRET_KEY or separate)
ADMIN_SECRET_KEY=change-me-use-a-different-long-random-string

# Admin login credentials
ADMIN_USERNAME=admin

# Generate bcrypt hash: python3 -c "import bcrypt; print(bcrypt.hashpw(b'YourPassword', bcrypt.gensalt(12)).decode())"
# Default value below is the hash of "admin123" — CHANGE THIS IN PRODUCTION
ADMIN_PASSWORD_HASH=$2b$12$eQzYk1bvJ9W7NmCqL3xKh.placeholder.hash.change.me

# ── App Identity ─────────────────────────────────────────────────────────────

BUSINESS_NAME=Foreman AI
BUSINESS_TYPE=General Contractor
AI_NAME=Foreman AI
GST_RATE=0.05

# Full URL of your deployed app (no trailing slash)
APP_BASE_URL=https://your-app.onrender.com

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
# For local dev: http://localhost:8000,http://127.0.0.1:8000
# For production: https://your-app.onrender.com,https://yourdomain.com
ALLOWED_ORIGINS=https://your-app.onrender.com

# ── AI / LLM ─────────────────────────────────────────────────────────────────

# OpenAI — get from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Anthropic (optional) — get from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ── Email / SMTP ─────────────────────────────────────────────────────────────
# Used for: password reset emails, invoice emails, welcome emails
#
# Gmail setup:
#   1. Enable 2FA on your Google account
#   2. Go to myaccount.google.com → Security → App Passwords
#   3. Generate an App Password for "Mail"
#   4. Use that 16-char password as SMTP_PASS
#
# SendGrid setup:
#   SMTP_HOST=smtp.sendgrid.net
#   SMTP_PORT=587
#   SMTP_USER=apikey
#   SMTP_PASS=SG.your-sendgrid-api-key
#
# Leave blank to disable email features (app still works without email)

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-16-char-app-password
SMTP_FROM=your-gmail@gmail.com
SMTP_FROM_NAME=Foreman AI

# ── Stripe (Optional — for billing/payments) ─────────────────────────────────
# Get from https://dashboard.stripe.com/apikeys
# Leave blank to disable Stripe features

STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...

# ── Runtime / Storage ────────────────────────────────────────────────────────

DEBUG=false
DEBUG_MODE=false

# Port to run on (Render sets $PORT automatically — do not set manually on Render)
PORT=8000

# Where to store persistent JSON data files
# On Render: use /opt/render/project/src/data (add a Render Disk for persistence)
# Locally: use ./data
DATA_DIR=./data

# Path to the settings JSON file
SETTINGS_FILE=./data/settings.json

# How long admin JWT tokens remain valid (hours)
ADMIN_TOKEN_EXPIRE_HOURS=24

# ============================================================
#  RENDER-SPECIFIC NOTES
# ============================================================
# 1. SECRET_KEY and ADMIN_SECRET_KEY: Use "Generate Value" in Render
# 2. DATA_DIR: Render free tier does NOT persist disk between deploys.
#    Add a Render Disk (paid) mounted at /opt/render/project/src/data
#    for persistent user data. Without a disk, data resets on redeploy.
# 3. ALLOWED_ORIGINS: Set to your actual Render URL after first deploy
# 4. APP_BASE_URL: Required for password reset email links to work
# 5. OPENAI_API_KEY: Required for AI features; app runs without it
#    but AI assistant will return errors
# ============================================================